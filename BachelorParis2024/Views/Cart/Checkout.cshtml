@using BachelorParis2024.Domain.Models;

@model CartItemViewModel;

@{
    ViewData["Title"] = "Checkout";
}



@section header {
    <div id="header" class="header text-center">
        <div class="logoSite container container-fluid d-block d-flex align-items-center justify-content-center">
            <img class="logo-flamme-header img-fluid" src="~/images/logos_jo/flamme.png" alt="logo flamme olympique" height="50%" />
            <h1 class="d-block">PARIS 2024</h1>
            <img class="logo-anneaux-header img-fluid" src="~/images/logos_jo/anneaux.png" alt="logo anneaux olympics" height="30%" />
        </div>
        <h2 class="d-block d-flex align-items-start justify-content-center">Billetterie</h2>
    </div>
}

@section main {
    <div id="main" class="main main_events text-center bg_light-blue d-flex align-items-center justify-content-center">
        <div class="cart table-background">
            <div class="col container container-fluid" id="js-cartContainer">
            @if (Model != null)
            {   <h3 class="checkoutTitle">Récapitulatif de votre commande</h3>
                    <section class="row row-cols-lg-4 checkoutSubtitle">
                    <div class="col">
                        <h6>&Eacutevénement</h6>
                    </div>
                     <div class="col">
                        <h6>Offre</h6>
                     </div>
                     <div class="col">
                        <h6>Quantité</h6>
                     </div>
                     <div class="col">
                        <h6>Total</h6>
                     </div>
                </section>
                @foreach (var item in Model.CartItems)
                {
                    <section class="row row-cols-lg-4 checkoutItem">
                        <div class="col">
                            <h4>@item.Sport</h4>
                            <h5>@item.Event</h5>
                            <p>@item.Date</p>
                            <p>@item.Location></p>
                        </div>
                        <div class="col">
                            <p>@item.OfferName</p>
                            <p>@item.OfferDescription</p>
                            <p>@item.Price</p>
                        </div>
                        <div class="col">
                            <p>@item.Quantity</p>
                        </div>
                        <div class="col">
                            <p>@item.Total</p>
                        </div>
                    </section>
                }
                <section class="checkoutItem">
                    <h3>Montant Total du panier: @Model.Cart.TotalAmount</h3>
                </section>
                <section class="js-cartManage">
                    <div class="back js-pointer js-backToList link">
                        <img class="d-inline" src="~/images/icones/back.png" alt="retour à la liste" width="20rem" />
                        <p class="d-inline text-black">Retour à la liste des événements</p>
                    </div>
                        <div class="btn btn_outline_blue js-goToPayment" title="passer au paiement">Passer au paiement</div>
                </section>
            }
            else
            {
                <h3>Votre panier est vide</h3>
            }
            </div>
        </div>        
    </div>
}

@section scripts {
    <script src="~/js/payment.js" asp-append-version="true"></script>
}
