@model BachelorParis2024.Domain.Models.OfferModel

@{
    ViewData["Title"] = "Delete";
}

@section header {
    <div id="header" class="header text-center">
        <div class="logoSite container container-fluid d-block d-flex align-items-center justify-content-center">
            <img class="logo-flamme-header img-fluid" src="~/images/logos_jo/flamme.png" alt="logo flamme olympique" height="50%" />
            <h1 class="d-block">PARIS 2024</h1>
            <img class="logo-anneaux-header img-fluid" src="~/images/logos_jo/anneaux.png" alt="logo anneaux olympics" height="30%" />
        </div>
        <h2 class="d-block d-flex align-items-start justify-content-center">Gestion des offres</h2>
    </div>
}

@section main {
    <div id="main" class="main text-center flex-centered">

        <h2>Supprimer</h2>

        <h3>Are you sure you want to delete this?</h3>
        <div>
            <h4>OfferModel</h4>
            <hr />
            <dl class="row">
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.Name)
                </dd>
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.PersonsNumber)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.PersonsNumber)
                </dd>
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.Description)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.Description)
                </dd>
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.Price)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.Price)
                </dd>
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.Conditions)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.Conditions)
                </dd>
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.ImageUrl)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.ImageUrl)
                </dd>
            </dl>
    
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete" class="btn btn-danger" /> |
                <a asp-action="Index">Retour à la liste</a>
            </form>
        </div>
    </div>
}
