@model BachelorParis2024.Domain.Models.OfferModel

@{
    ViewData["Title"] = "Details";
}

@section header {
    <div id="header" class="header text-center">
        <div class="logoSite container container-fluid d-block d-flex align-items-center justify-content-center">
            <img class="logo-flamme-header img-fluid" src="~/images/logos_jo/flamme.png" alt="logo flamme olympique" height="50%" />
            <h1 class="d-block">PARIS 2024</h1>
            <img class="logo-anneaux-header img-fluid" src="~/images/logos_jo/anneaux.png" alt="logo anneaux olympics" height="30%" />
        </div>
        <h2 class="d-block d-flex align-items-start justify-content-center">Gestion des offres</h2>
    </div>
}

@section main {
    <div id="main" class="main">
        <section class="mb-4">
            <h4 class="mainTitle">Détail de l'offre</h4>
            <div class="offerForm">
                <dl class="row">
                    <dt class = "col-sm-2 text-end">
                        Nom
                    </dt>
                    <dd class = "col-sm-10 text-start">
                        @Html.DisplayFor(model => model.Name)
                    </dd>
                    <dt class = "col-sm-2 text-end">
                        Nombre de personnes
                    </dt>
                    <dd class="col-sm-10 text-start">
                        @Html.DisplayFor(model => model.PersonsNumber)
                    </dd>
                    <dt class = "col-sm-2 text-end">
                        Description
                    </dt>
                    <dd class="col-sm-10 text-start">
                        @Html.DisplayFor(model => model.Description)
                    </dd>
                    <dt class="col-sm-2 text-end">
                        Prix en €
                    </dt>
                    <dd class="col-sm-10 text-start">
                        @Html.DisplayFor(model => model.Price)
                    </dd>
                    <dt class="col-sm-2 text-end">
                        Conditions et modalités d'accès
                    </dt>
                    <dd class="col-sm-10 text-start">
                        @Html.DisplayFor(model => model.Conditions)
                    </dd>
                    <dt class="col-sm-2 text-end">
                        Image
                    </dt>
                    <dd class="col-sm-10 text-start">
                        @Html.DisplayFor(model => model.ImageUrl)
                    </dd>
                </dl>
                <div>
                    <a class="link m-4 d-block" asp-action="Edit" asp-route-id="@Model?.Id">Editer</a>
                </div>
            </div>
        </section>
        
        <div class="back">
            <a class="link" asp-action="Index">
                <img class="d-inline" src="~/images/icones/back.png" alt="retour à la liste" width="20rem" />
                <p class="d-inline text-black">Retour à la liste</p>
            </a>
        </div>
    </div>
    
}
