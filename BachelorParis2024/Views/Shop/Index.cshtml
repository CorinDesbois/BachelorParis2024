@using BachelorParis2024.Domain.Models;

@{
    ViewData["Title"] = "Billetterie en ligne";
}

@model IEnumerable<OfferModel>

@section header {
<div id="header" class="header text-center">
        <div class="logoSite container container-fluid d-block d-flex align-items-center justify-content-center">
            <img class="logo-flamme-header img-fluid" src="~/images/logos_jo/flamme.png" alt="logo flamme olympique" height="50%"/>
            <h1 class="d-block">PARIS 2024</h1>
            <img class="logo-anneaux-header img-fluid" src="~/images/logos_jo/anneaux.png" alt="logo anneaux olympics" height ="30%"/>     
        </div>
        <h2 class="d-block d-flex align-items-start justify-content-center">Billetterie</h2>

</div>
}

@section main {
    <div id="main" class="main main__offers text-center flex-centered">
        <!--A mettre en BDD-->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row__offers">

        @foreach (var offer in Model)
        {
            <div class="col">
                <div class="card card__offer bg_gold container container-fluid d-flex">
                    <h3 class="card-header text-white">@Html.DisplayFor(modelItem => offer.Name)</h3>
                    <img class="img-offre img-fluid" src="~/images/logos_jo/@offer.ImageUrl" alt="offre solo"/>
                    <a class="btn_small btn_small__offers text-decoration-none flex-centered container container-fluid bg_blue text-white rounded-pill flex-centered justify-self-center" 
                    asp-action="OfferDetail" asp-route-id="@offer.Id">
                        Voir l'offre
                    </a>
                </div>
            </div>
        }
 
            
        </div>
    </div>
}
