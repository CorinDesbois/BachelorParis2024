@{
    ViewData["Title"] = "Billetterie en ligne";
}

@section header {
<div id="header" class="header text-center">
        <div class="logoSite container container-fluid d-block d-flex align-items-center justify-content-center">
            <img class="logo-flamme-header img-fluid" src="~/images/logos_jo/flamme.png" alt="logo flamme olympique" height="50%"/>
            <h1 class="d-block">PARIS 2024</h1>
            <img class="logo-anneaux-header img-fluid" src="~/images/logos_jo/anneaux.png" alt="logo anneaux olympics" height ="30%"/>
                
        </div>
        <h2 class="d-block d-flex align-items-start justify-content-center">Billetterie</h2>

</div>
}

@section main {
    <div id="main" class="main text-center flex-centered">
        <!--A mettre en BDD-->
        <div class="card card__offer bg_gold">
            <h3 class="card-header text-white">SOLO</h3>
            <img class="img-offre img-fluid" src="~/images/logos_jo/solo.png" alt="offre solo"/>
            <div class="btn_small bg_blue text-white rounded-pill container-fluid align-self-center">
                Voir l'offre
            </div>
        </div>
        <div class="card card__offer bg_gold">
            <h3 class="card-header text-white">DUO</h3>
            <img class="img-offre img-fluid" src="~/images/logos_jo/frigy_duo.png" alt="offre duo" />
            <div class="btn_small bg_blue text-white rounded-pill container-fluid align-self-center">
                Voir l'offre
            </div>
        </div>
        <div class="card card__offer bg_gold">
            <h3 class="card-header text-white">FAMILLE</h3>
            <img class="img-offre img-fluid" src="~/images/logos_jo/family.png" alt="offre famille" />
            <div class="btn_small bg_blue text-white rounded-pill container-fluid align-self-center">
                Voir l'offre
            </div>
        </div>
    </div>
}
